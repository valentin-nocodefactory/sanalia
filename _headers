# Cloudflare Pages — cache policies
# ───────────────────────────────────────────────────────────────
# Les pages HTML doivent toujours être revalidées : sinon les MAJ
# (nouvelle version d'un script JSX, fix de bug, etc.) ne sont
# jamais propagées tant que le user n'a pas vidé son cache.
/*
  Cache-Control: public, max-age=0, must-revalidate

# Les assets immutables (CSS/JS/images avec query string ?v=X
# ou hash) peuvent être cachés longtemps : ils ne changent jamais
# pour une URL donnée.
/css/*
  Cache-Control: public, max-age=31536000, immutable
/js/*
  Cache-Control: public, max-age=31536000, immutable
/fonts/*
  Cache-Control: public, max-age=31536000, immutable
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Les modules React de l'app devis ont un ?v=N dans l'URL : on peut
# les cacher long, le bump du v= force la refetch côté HTML.
/devis-paiement/*.jsx
  Cache-Control: public, max-age=31536000, immutable
/devis-paiement/styles.css
  Cache-Control: public, max-age=31536000, immutable
/devis-paiement/quote-pdf.js
  Cache-Control: public, max-age=31536000, immutable
